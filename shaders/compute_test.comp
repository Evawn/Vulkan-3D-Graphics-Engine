#version 450

layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;

layout(set = 0, binding = 0, rgba8) uniform writeonly image2D outputImage;

layout(push_constant) uniform PushConstants {
    float width;
    float height;
} pc;

void main() {
    ivec2 pixel = ivec2(gl_GlobalInvocationID.xy);
    if (pixel.x >= int(pc.width) || pixel.y >= int(pc.height)) return;

    vec2 uv = vec2(pixel) / vec2(pc.width, pc.height);

    // Procedural gradient: red=x, green=y, blue=sinusoidal pattern
    float blue = 0.5 + 0.5 * sin(uv.x * 20.0 + uv.y * 20.0);
    vec4 color = vec4(uv.x, uv.y, blue, 1.0);

    imageStore(outputImage, pixel, color);
}
